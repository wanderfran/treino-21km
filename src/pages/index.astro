---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Calendar from '../components/Calendar.astro';
import TrainingCard from '../components/TrainingCard.astro';
import ZoneCard from '../components/ZoneCard.astro';
import dados from '../data/treinos.json';

const { meta, zonas, treinos } = dados;
---

<Layout title="Treino 21km">
  <Header
    titulo={meta.prova}
    subtitulo={`Preparacao para a prova`}
    dataProva={meta.dataProva}
  />

  <Calendar mes="Abril" ano={2026} treinos={treinos} />

  <!-- Tabs de navegacao -->
  <div class="px-5 mb-6">
    <div class="flex gap-2 p-1 bg-dark-card border border-dark-border rounded-xl">
      <button class="flex-1 py-2.5 px-4 bg-lime text-dark rounded-lg text-sm font-semibold">
        Treinos
      </button>
      <button class="flex-1 py-2.5 px-4 text-gray-text rounded-lg text-sm font-medium hover:text-white transition-colors">
        Zonas FC
      </button>
      <button class="flex-1 py-2.5 px-4 text-gray-text rounded-lg text-sm font-medium hover:text-white transition-colors">
        Dicas
      </button>
    </div>
  </div>

  <!-- Treinos da semana -->
  <section class="px-5 mb-6">
    <div class="flex items-center justify-between mb-4">
      <h2 class="text-lg font-bold">Treinos da Semana</h2>
      <span class="text-xs text-gray-text">{treinos.length} sessoes</span>
    </div>
    <div class="space-y-4">
      {treinos.map(treino => (
        <TrainingCard {...treino} />
      ))}
    </div>
  </section>

  <!-- Zonas de FC -->
  <section class="px-5 mb-6">
    <h2 class="text-lg font-bold mb-4">Zonas de Frequencia Cardiaca</h2>
    <div class="space-y-3">
      {zonas.map(zona => (
        <ZoneCard {...zona} />
      ))}
    </div>
  </section>

  <!-- Tabela de Paces -->
  <section class="px-5 mb-6">
    <h2 class="text-lg font-bold mb-4">Tabela de Paces</h2>
    <div class="bg-dark-card border border-dark-border rounded-2xl overflow-hidden">
      <div class="grid grid-cols-3 gap-px bg-dark-border">
        <div class="bg-dark-card p-3 text-center">
          <p class="text-[10px] text-gray-text uppercase mb-1">Zona</p>
          <p class="text-xs font-semibold text-lime">Z2</p>
        </div>
        <div class="bg-dark-card p-3 text-center">
          <p class="text-[10px] text-gray-text uppercase mb-1">Pace</p>
          <p class="text-xs font-semibold">6:26-7:15</p>
        </div>
        <div class="bg-dark-card p-3 text-center">
          <p class="text-[10px] text-gray-text uppercase mb-1">FC</p>
          <p class="text-xs font-semibold">108-125</p>
        </div>
      </div>
      <div class="grid grid-cols-3 gap-px bg-dark-border">
        <div class="bg-dark-card p-3 text-center">
          <p class="text-xs font-semibold text-lime">Z3</p>
        </div>
        <div class="bg-dark-card p-3 text-center">
          <p class="text-xs font-semibold">6:26-7:15</p>
        </div>
        <div class="bg-dark-card p-3 text-center">
          <p class="text-xs font-semibold">125-144</p>
        </div>
      </div>
      <div class="grid grid-cols-3 gap-px bg-dark-border">
        <div class="bg-dark-card p-3 text-center">
          <p class="text-xs font-semibold text-lime">Z4</p>
        </div>
        <div class="bg-dark-card p-3 text-center">
          <p class="text-xs font-semibold">5:48-6:26</p>
        </div>
        <div class="bg-dark-card p-3 text-center">
          <p class="text-xs font-semibold">144-162</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Dicas -->
  <section class="px-5 mb-6">
    <h2 class="text-lg font-bold mb-4">Dicas Importantes</h2>
    <div class="space-y-3">
      <div class="bg-dark-card border border-dark-border rounded-xl p-4">
        <div class="flex items-center gap-3 mb-2">
          <div class="w-8 h-8 rounded-full bg-lime/20 flex items-center justify-center">
            <span class="text-lime text-sm">1</span>
          </div>
          <h4 class="font-semibold text-sm">Descanso</h4>
        </div>
        <p class="text-xs text-gray-text leading-relaxed">
          Dias sem treino sao para descanso real. Durma 7-8 horas e hidrate-se bem durante o dia.
        </p>
      </div>

      <div class="bg-dark-card border border-dark-border rounded-xl p-4">
        <div class="flex items-center gap-3 mb-2">
          <div class="w-8 h-8 rounded-full bg-lime/20 flex items-center justify-center">
            <span class="text-lime text-sm">2</span>
          </div>
          <h4 class="font-semibold text-sm">Alimentacao</h4>
        </div>
        <p class="text-xs text-gray-text leading-relaxed">
          Coma 1-2h antes do treino. Pos-treino: proteina + carboidrato em ate 30 minutos.
        </p>
      </div>

      <div class="bg-dark-card border border-dark-border rounded-xl p-4">
        <div class="flex items-center gap-3 mb-2">
          <div class="w-8 h-8 rounded-full bg-lime/20 flex items-center justify-center">
            <span class="text-lime text-sm">3</span>
          </div>
          <h4 class="font-semibold text-sm">Monitoramento</h4>
        </div>
        <p class="text-xs text-gray-text leading-relaxed">
          Use o Garmin para acompanhar FC. Registre como se sentiu. Sentiu dor? Tire um dia extra.
        </p>
      </div>
    </div>
  </section>

  <!-- Footer -->
  <footer class="px-5 pb-8 pt-4">
    <div class="text-center">
      <p class="text-xs text-gray-text">Semana {meta.semanaAtual}/{meta.totalSemanas}</p>
      <p class="text-[10px] text-gray-text/50 mt-1">Treino 21km</p>
    </div>
  </footer>

  <!-- Bottom Navigation -->
  <nav class="fixed bottom-0 left-0 right-0 bg-dark-card/95 backdrop-blur border-t border-dark-border safe-area-inset-bottom">
    <div class="max-w-md mx-auto flex justify-around py-3">
      <button class="flex flex-col items-center gap-1 text-lime">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"></path>
        </svg>
        <span class="text-[10px] font-medium">Home</span>
      </button>
      <button class="flex flex-col items-center gap-1 text-gray-text">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
        </svg>
        <span class="text-[10px] font-medium">Calendario</span>
      </button>
      <button class="flex flex-col items-center gap-1 text-gray-text">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"></path>
        </svg>
        <span class="text-[10px] font-medium">Progresso</span>
      </button>
      <button class="flex flex-col items-center gap-1 text-gray-text">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path>
        </svg>
        <span class="text-[10px] font-medium">Perfil</span>
      </button>
    </div>
  </nav>

  <!-- Spacer para o bottom nav -->
  <div class="h-20"></div>
</Layout>
