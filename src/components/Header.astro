---
interface Props {
  titulo: string;
  subtitulo: string;
  dataProva: string;
}

const { titulo, subtitulo, dataProva } = Astro.props;

const hoje = new Date();
const prova = new Date(dataProva);
const diffTime = prova.getTime() - hoje.getTime();
const diasRestantes = Math.ceil(diffTime / (1000 * 60 * 60 * 24));
---

<header class="text-center py-8 px-4 bg-gradient-to-r from-running-blue to-running-purple rounded-2xl mb-8 shadow-2xl">
  <h1 class="text-2xl sm:text-3xl md:text-4xl font-bold mb-2">{titulo}</h1>
  <p class="text-base sm:text-lg opacity-90 mb-4">{subtitulo}</p>

  <div class="inline-block bg-white/10 backdrop-blur px-6 py-3 rounded-xl">
    <span class="text-sm sm:text-base">Faltam </span>
    <span class="text-2xl sm:text-3xl font-bold text-running-accent">{diasRestantes}</span>
    <span class="text-sm sm:text-base"> dias para a prova!</span>
  </div>
</header>
