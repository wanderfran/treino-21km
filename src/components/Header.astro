---
interface Props {
  titulo: string;
  subtitulo: string;
  dataProva: string;
}

const { titulo, subtitulo, dataProva } = Astro.props;

const hoje = new Date();
const prova = new Date(dataProva);
const diffTime = prova.getTime() - hoje.getTime();
const diasRestantes = Math.ceil(diffTime / (1000 * 60 * 60 * 24));
---

<header class="px-5 pt-12 pb-6">
  <div class="flex items-center justify-between mb-6">
    <div>
      <p class="text-gray-text text-sm mb-1">Preparacao</p>
      <h1 class="text-3xl font-bold tracking-tight">Meia Maratona</h1>
    </div>
    <div class="w-12 h-12 rounded-full bg-lime flex items-center justify-center">
      <span class="text-dark font-bold text-lg">21k</span>
    </div>
  </div>

  <div class="bg-dark-card border border-dark-border rounded-2xl p-4 flex items-center justify-between">
    <div>
      <p class="text-gray-text text-xs mb-1">Faltam para a prova</p>
      <p class="text-2xl font-bold">
        <span class="text-lime">{diasRestantes}</span>
        <span class="text-base font-normal text-gray-text ml-1">dias</span>
      </p>
    </div>
    <div class="text-right">
      <p class="text-gray-text text-xs mb-1">Data da prova</p>
      <p class="font-semibold">31/07/2026</p>
    </div>
  </div>
</header>
