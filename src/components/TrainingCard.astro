---
interface Props {
  diaSemana: string;
  data: string;
  tipo: string;
  zona: string;
  distancia: string;
  pace: string;
  tempo: string;
  fc: string;
  percurso: string;
  instrucoes: string[];
}

const { diaSemana, data, tipo, zona, distancia, pace, tempo, fc, percurso, instrucoes } = Astro.props;

const getZonaInfo = (zona: string) => {
  switch(zona) {
    case 'z2': return { cor: 'bg-green-500', nome: 'Regenerativa', emoji: '🟢' };
    case 'z3': return { cor: 'bg-yellow-500', nome: 'Moderada', emoji: '🟡' };
    case 'z4': return { cor: 'bg-orange-500', nome: 'Estabilidade', emoji: '🟠' };
    default: return { cor: 'bg-gray-500', nome: '', emoji: '' };
  }
};

const zonaInfo = getZonaInfo(zona);
const dataObj = new Date(data);
const diaNum = dataObj.getDate();
const mesAbrev = dataObj.toLocaleDateString('pt-BR', { month: 'short' }).replace('.', '');
---

<div class="bg-dark-card border border-dark-border rounded-2xl overflow-hidden">
  <!-- Header do card -->
  <div class="p-4 flex items-center gap-4">
    <div class="w-14 h-14 rounded-xl bg-lime flex flex-col items-center justify-center shrink-0">
      <span class="text-dark text-lg font-bold leading-none">{diaNum}</span>
      <span class="text-dark text-[10px] font-medium uppercase">{mesAbrev}</span>
    </div>
    <div class="flex-1 min-w-0">
      <div class="flex items-center gap-2 mb-1">
        <span class="text-lime text-xs font-semibold uppercase">{tipo}</span>
        <span class="text-gray-text text-xs">• {zonaInfo.nome}</span>
      </div>
      <h3 class="text-lg font-bold truncate">{distancia} Run</h3>
    </div>
    <div class="text-right">
      <p class="text-xs text-gray-text mb-1">Tempo</p>
      <p class="text-sm font-semibold text-lime">{tempo.split(' a ')[0]}</p>
    </div>
  </div>

  <!-- Detalhes -->
  <div class="px-4 pb-4">
    <div class="grid grid-cols-3 gap-2 mb-4">
      <div class="bg-dark rounded-xl p-3 text-center">
        <p class="text-[10px] text-gray-text uppercase mb-1">Pace</p>
        <p class="text-xs font-semibold">{pace.split(' - ')[0]}</p>
      </div>
      <div class="bg-dark rounded-xl p-3 text-center">
        <p class="text-[10px] text-gray-text uppercase mb-1">FC</p>
        <p class="text-xs font-semibold">{fc.split('-')[0]}-{fc.split('-')[1]}</p>
      </div>
      <div class="bg-dark rounded-xl p-3 text-center">
        <p class="text-[10px] text-gray-text uppercase mb-1">Zona</p>
        <p class="text-xs font-semibold">{zona.toUpperCase()}</p>
      </div>
    </div>

    <!-- Instrucoes expandiveis -->
    <details class="group">
      <summary class="flex items-center justify-between cursor-pointer py-2 text-sm font-medium text-gray-text hover:text-white transition-colors">
        <span>Como executar</span>
        <svg class="w-4 h-4 transform group-open:rotate-180 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
        </svg>
      </summary>
      <ul class="mt-2 space-y-2 text-sm text-gray-text">
        {instrucoes.map(instrucao => (
          <li class="flex gap-2 items-start">
            <span class="text-lime mt-1">•</span>
            <span>{instrucao}</span>
          </li>
        ))}
      </ul>
    </details>
  </div>

  <!-- Botao -->
  <button class="w-full py-4 bg-lime text-dark font-bold text-sm uppercase tracking-wide hover:bg-lime-dark transition-colors">
    Iniciar Treino
  </button>
</div>
