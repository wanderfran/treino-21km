---
interface Props {
  diaSemana: string;
  data: string;
  tipo: string;
  zona: string;
  distancia: string;
  pace: string;
  tempo: string;
  fc: string;
  percurso: string;
  instrucoes: string[];
}

const { diaSemana, data, tipo, zona, distancia, pace, tempo, fc, percurso, instrucoes } = Astro.props;

const getBorderColor = (zona: string) => {
  switch(zona) {
    case 'z2': return 'border-l-green-500';
    case 'z3': return 'border-l-yellow-500';
    case 'z4': return 'border-l-orange-500';
    default: return 'border-l-gray-500';
  }
};

const getBadgeClass = (tipo: string) => {
  switch(tipo.toLowerCase()) {
    case 'longo': return 'bg-green-500 text-black';
    case 'continuo': return 'bg-yellow-500 text-black';
    case 'ritmo': return 'bg-orange-500 text-black';
    default: return 'bg-gray-500 text-white';
  }
};

const getZonaNome = (zona: string) => {
  switch(zona) {
    case 'z2': return 'Regenerativa';
    case 'z3': return 'Moderada';
    case 'z4': return 'Estabilidade';
    default: return '';
  }
};

const dataFormatada = new Date(data).toLocaleDateString('pt-BR', { day: '2-digit', month: '2-digit' });
---

<div class={`bg-white/5 rounded-xl p-5 border-l-4 ${getBorderColor(zona)} hover:bg-white/10 transition-all`}>
  <div class="flex flex-wrap justify-between items-center gap-2 mb-4">
    <span class="text-sm opacity-70">{diaSemana}, {dataFormatada}</span>
    <span class={`px-3 py-1 rounded-full text-xs font-bold uppercase ${getBadgeClass(tipo)}`}>
      {tipo}
    </span>
  </div>

  <h3 class="text-xl sm:text-2xl font-bold mb-4">
    Corrida {tipo === 'Longo' ? 'Longa' : tipo === 'Continuo' ? 'Continua' : 'de Ritmo'} - {distancia}
  </h3>

  <div class="grid grid-cols-2 gap-3 mb-4">
    <div class="bg-white/5 rounded-lg p-3">
      <div class="text-xs opacity-60 mb-1">Distancia</div>
      <div class="font-bold">{distancia}</div>
    </div>
    <div class="bg-white/5 rounded-lg p-3">
      <div class="text-xs opacity-60 mb-1">Intensidade</div>
      <div class="font-bold">{zona.toUpperCase()} - {getZonaNome(zona)}</div>
    </div>
    <div class="bg-white/5 rounded-lg p-3">
      <div class="text-xs opacity-60 mb-1">Pace</div>
      <div class="font-bold text-sm">{pace}</div>
    </div>
    <div class="bg-white/5 rounded-lg p-3">
      <div class="text-xs opacity-60 mb-1">Tempo Total</div>
      <div class="font-bold text-sm">{tempo}</div>
    </div>
    <div class="bg-white/5 rounded-lg p-3">
      <div class="text-xs opacity-60 mb-1">Frequencia Cardiaca</div>
      <div class="font-bold">{fc}</div>
    </div>
    <div class="bg-white/5 rounded-lg p-3">
      <div class="text-xs opacity-60 mb-1">Percurso</div>
      <div class="font-bold">{percurso}</div>
    </div>
  </div>

  <details class="group">
    <summary class="cursor-pointer text-running-accent font-semibold flex items-center gap-2">
      <span>Como executar</span>
      <svg class="w-4 h-4 transform group-open:rotate-180 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
      </svg>
    </summary>
    <ul class="mt-3 space-y-2 text-sm">
      {instrucoes.map(instrucao => (
        <li class="flex gap-2">
          <span class="text-running-accent">-</span>
          <span>{instrucao}</span>
        </li>
      ))}
    </ul>
  </details>
</div>
