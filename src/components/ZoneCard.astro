---
interface Props {
  id: string;
  nome: string;
  fc: string;
  descricao: string;
}

const { id, nome, fc, descricao } = Astro.props;

const getZoneStyle = (id: string) => {
  switch(id) {
    case 'z2': return { bg: 'bg-green-500/20', border: 'border-green-500/30', dot: 'bg-green-500' };
    case 'z3': return { bg: 'bg-yellow-500/20', border: 'border-yellow-500/30', dot: 'bg-yellow-500' };
    case 'z4': return { bg: 'bg-orange-500/20', border: 'border-orange-500/30', dot: 'bg-orange-500' };
    default: return { bg: 'bg-gray-500/20', border: 'border-gray-500/30', dot: 'bg-gray-500' };
  }
};

const style = getZoneStyle(id);
---

<div class={`${style.bg} border ${style.border} rounded-xl p-4 flex items-center gap-4`}>
  <div class={`w-10 h-10 ${style.dot} rounded-full flex items-center justify-center shrink-0`}>
    <span class="text-dark font-bold text-sm">{id.toUpperCase()}</span>
  </div>
  <div class="flex-1 min-w-0">
    <div class="flex items-center justify-between mb-1">
      <h4 class="font-semibold text-sm">{nome}</h4>
      <span class="text-xs text-gray-text">{fc}</span>
    </div>
    <p class="text-xs text-gray-text line-clamp-2">{descricao}</p>
  </div>
</div>
