---
interface Treino {
  data: string;
  distancia: string;
  zona: string;
  tipo: string;
}

interface Props {
  mes: string;
  ano: number;
  treinos: Treino[];
}

const { mes, ano, treinos } = Astro.props;

const diasSemana = ['D', 'S', 'T', 'Q', 'Q', 'S', 'S'];

// Abril 2026 comeca na quarta-feira (indice 3)
const primeiroDia = 3;
const totalDias = 30;

// Criar array de treinos por dia
const treinosPorDia: Record<number, Treino> = {};
treinos.forEach(t => {
  const dia = new Date(t.data).getDate();
  treinosPorDia[dia] = t;
});

// Criar array de dias do calendario (2 semanas: 6-18)
const diasCalendario: (number | null)[] = [];
// Semana do dia 5-11 (começa no domingo dia 5)
for (let i = 5; i <= 11; i++) {
  diasCalendario.push(i);
}
// Semana do dia 12-18
for (let i = 12; i <= 18; i++) {
  diasCalendario.push(i);
}
---

<section class="px-5 mb-6">
  <div class="flex items-center justify-between mb-4">
    <h2 class="text-xl font-bold">Semana 1/12</h2>
    <span class="text-lime text-sm font-medium">{mes} {ano}</span>
  </div>

  <div class="bg-dark-card border border-dark-border rounded-2xl p-4">
    <!-- Dias da semana -->
    <div class="grid grid-cols-7 gap-1 mb-2">
      {diasSemana.map(dia => (
        <div class="text-center text-gray-text text-xs font-medium py-2">
          {dia}
        </div>
      ))}
    </div>

    <!-- Grid do calendario -->
    <div class="grid grid-cols-7 gap-1">
      {diasCalendario.map(dia => {
        const treino = dia ? treinosPorDia[dia] : null;
        const isTreino = !!treino;
        const isToday = dia === 6; // Simular hoje como dia 6

        return (
          <div class={`
            aspect-square flex flex-col items-center justify-center rounded-xl text-sm font-medium
            transition-all duration-200
            ${isTreino
              ? 'bg-lime text-dark'
              : isToday
                ? 'bg-dark-border text-white'
                : 'text-gray-text hover:bg-dark-border/50'}
          `}>
            <span class={`${isTreino ? 'font-bold' : ''}`}>{dia}</span>
            {isTreino && (
              <span class="text-[8px] font-bold mt-0.5 opacity-80">
                {treino.distancia.replace(' km', '')}km
              </span>
            )}
          </div>
        );
      })}
    </div>

    <!-- Legenda -->
    <div class="flex items-center justify-center gap-4 mt-4 pt-4 border-t border-dark-border">
      <div class="flex items-center gap-2">
        <div class="w-3 h-3 rounded-full bg-lime"></div>
        <span class="text-xs text-gray-text">Treino</span>
      </div>
      <div class="flex items-center gap-2">
        <div class="w-3 h-3 rounded-full bg-dark-border"></div>
        <span class="text-xs text-gray-text">Hoje</span>
      </div>
    </div>
  </div>
</section>
